{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r brandiq_app/requirements.txt"
  },
  "deploy": {
    "startCommand": "cd brandiq_app && gunicorn app:app --bind 0.0.0.0:$PORT --timeout 120",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}